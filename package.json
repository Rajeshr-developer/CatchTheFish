{
  "name": "catchthefish",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "bundle": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "assemble": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "web": "webpack serve --config webpack.config.js",
    "build": "cross-env NODE_ENV=production webpack --config webpack.config.js"
  },
  "dependencies": {
    "react": "18.1.0",
    "react-dom": "^18.1.0",
    "react-native": "0.70.0",
    "react-native-animated-sprite": "^0.11.1",
    "react-native-gesture-handler": "^2.6.1",
    "react-native-sprite-sheet": "^0.0.3",
    "react-native-web": "^0.21.2",
    "rn-sprite-sheet": "^1.1.12"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.12.5",
    "@react-native-community/eslint-config": "^2.0.0",
    "@tsconfig/react-native": "^2.0.2",
    "@types/jest": "^26.0.23",
    "@types/react-native": "^0.70.0",
    "@types/react-test-renderer": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^5.37.0",
    "@typescript-eslint/parser": "^5.37.0",
    "ajv": "^8.20.0",
    "babel-jest": "^26.6.3",
    "babel-loader": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^7.32.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^26.6.3",
    "metro-react-native-babel-preset": "^0.72.1",
    "prettier": "^2.7.1",
    "react-test-renderer": "18.1.0",
    "typescript": "^4.8.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.2"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
